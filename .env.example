# ============================================
# AI INTERVIEWER - ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values
# ⚠️  NEVER COMMIT .env TO VERSION CONTROL
# ============================================

# === REQUIRED - Application will not start without these ===

# Database - PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_interviewer

# Redis - For caching, sessions, and Celery
REDIS_URL=redis://localhost:6379/0

# JWT Secret - Generate with: openssl rand -hex 32
SECRET_KEY=your-256-bit-secret-key-generate-with-openssl

# === ENVIRONMENT ===
ENVIRONMENT=development  # development, staging, production
DEBUG=true  # MUST be false in production
LOG_LEVEL=DEBUG  # DEBUG, INFO, WARNING, ERROR

# === AI SERVICES (At least one required for AI features) ===

# Groq API (RECOMMENDED - fastest, most reliable)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEYS=key1,key2,key3  # Multiple keys for rotation
GROQ_API_URL=https://api.groq.com/openai/v1

# Google Gemini (Alternative)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# AssemblyAI (Speech-to-Text)
# Get from: https://www.assemblyai.com/dashboard/signup
ASSEMBLYAI_API_KEY=your_assemblyai_key_here

# === INTERNAL SERVICE AUTHENTICATION ===
# Used for service-to-service communication
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=your-internal-api-key-for-services

# === EMAIL CONFIGURATION ===
EMAIL_PROVIDER=console  # console (dev), sendgrid, ses
SENDGRID_API_KEY=
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_FROM_NAME=AI Interviewer

# === FRONTEND URLS ===
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# === ML SERVICES (Docker containers) ===
SPEECH_SERVICE_URL=http://localhost:8001
VIDEO_SERVICE_URL=http://localhost:8002
FRAUD_SERVICE_URL=http://localhost:8003
NLP_SERVICE_URL=http://localhost:8004
INSIGHT_AGGREGATOR_URL=http://localhost:8005

# === OPTIONAL SERVICES ===

# Deepgram (Alternative STT)
DEEPGRAM_API_KEY=

# OpenAI (For NLP Engine)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic Claude (For NLP Engine)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# VideoSDK (Human-assisted interviews)
VIDEOSDK_API_KEY=
VIDEOSDK_SECRET=

# === PRODUCTION NOTES ===
# 1. Set ENVIRONMENT=production
# 2. Set DEBUG=false
# 3. Generate strong SECRET_KEY and INTERNAL_API_KEY
# 4. Use HTTPS URLs for all frontend URLs
# 5. Configure proper CORS_ORIGINS
# 6. Enable email provider (sendgrid/ses)
